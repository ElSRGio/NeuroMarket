# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neuromarket_v2
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Python Engine
PYTHON_ENGINE_URL=http://localhost:5000

# Server
NODE_ENV=development
PORT=3000

# Frontend
VITE_API_URL=http://localhost:3000

# Apify — Para datos reales de redes sociales
# Crea tu cuenta gratis en https://apify.com → Settings → Integrations → API token
APIFY_API_TOKEN=your_apify_token_here
